{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Report Generator",
  "version": "0.1.0",
  "identifier": "com.cy76.report_gen",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Report Generator",
        "width": 1366,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 760,
        "maximized": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
